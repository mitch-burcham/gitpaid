{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@engine/*": [
        "../src/lib/*"
      ]
    }
  },
  "include": [
    "src",
    "../src/lib"
  ]
}
